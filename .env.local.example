# ── Private Offer email delivery ─────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real credentials.

# Recipient for all Private Offer submissions
PRIVATE_OFFER_RECIPIENT=office@soletahomes.com

# SMTP credentials — use any provider (Gmail, Outlook, custom server, etc.)
# For Gmail: enable "App Passwords" under your Google account security settings.
# For custom SMTP: use the credentials provided by your host.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-sending-address@gmail.com
SMTP_PASS=your-app-password-here

# The From address shown in the outgoing email
SMTP_FROM="Soleta Website <your-sending-address@gmail.com>"
